diff --git a/mlx/backend/metal/CMakeLists.txt b/mlx/backend/metal/CMakeLists.txt
--- a/mlx/backend/metal/CMakeLists.txt
+++ b/mlx/backend/metal/CMakeLists.txt
@@ -1,3 +1,35 @@
+if(NOT MLX_METAL_SDK)
+  set(MLX_METAL_SDK macosx)
+endif()
+
+if(NOT MLX_METAL_COMPILER)
+  execute_process(
+    COMMAND xcrun --toolchain Metal -find metal
+    OUTPUT_VARIABLE MLX_METAL_COMPILER
+    OUTPUT_STRIP_TRAILING_WHITESPACE
+    RESULT_VARIABLE MLX_METAL_COMPILER_RESULT)
+  if(NOT MLX_METAL_COMPILER_RESULT EQUAL 0)
+    execute_process(
+      COMMAND xcrun -find metal
+      OUTPUT_VARIABLE MLX_METAL_COMPILER
+      OUTPUT_STRIP_TRAILING_WHITESPACE
+      COMMAND_ERROR_IS_FATAL ANY)
+  endif()
+endif()
+
+if(NOT MLX_METAL_SYSROOT)
+  execute_process(
+    COMMAND xcrun -sdk ${MLX_METAL_SDK} --show-sdk-path
+    OUTPUT_VARIABLE MLX_METAL_SYSROOT
+    OUTPUT_STRIP_TRAILING_WHITESPACE
+    COMMAND_ERROR_IS_FATAL ANY)
+endif()
+
+if(NOT MLX_METAL_MODULE_CACHE)
+  set(MLX_METAL_MODULE_CACHE ${CMAKE_CURRENT_BINARY_DIR}/module-cache)
+endif()
+file(MAKE_DIRECTORY ${MLX_METAL_MODULE_CACHE})
+
 function(make_jit_source SRC_FILE)
   # This function takes a metal header file, runs the C preprocessesor on it,
   # and makes the processed contents available as a string in a C++ function
@@ -13,8 +45,9 @@ function(make_jit_source SRC_FILE)
     OUTPUT jit/${SRC_NAME}.cpp
     COMMAND
       bash ${CMAKE_CURRENT_SOURCE_DIR}/make_compiled_preamble.sh
-      ${CMAKE_CURRENT_BINARY_DIR}/jit ${CMAKE_C_COMPILER} ${PROJECT_SOURCE_DIR}
-      ${SRC_FILE}
+      ${CMAKE_CURRENT_BINARY_DIR}/jit ${MLX_METAL_COMPILER}
+      ${PROJECT_SOURCE_DIR} ${SRC_FILE}
+      "-isysroot ${MLX_METAL_SYSROOT} -fmodules-cache-path=${MLX_METAL_MODULE_CACHE} ${MLX_METAL_MIN_VERSION_FLAG}"
     DEPENDS make_compiled_preamble.sh kernels/${SRC_FILE}.h ${ARGN})
   add_custom_target(${SRC_NAME} DEPENDS jit/${SRC_NAME}.cpp)
   add_dependencies(mlx ${SRC_NAME})
