+void extract_q6_k_data(
+    const gguf_tensor& tensor,
+    array& weights_arr,
+    array& scales_arr,
+    array& biases_arr) {
+  constexpr uint64_t weights_per_block = 256;
+  constexpr uint64_t bytes_per_block = 210;
+  if (tensor.weights_data == nullptr ||
+      tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error("[load_gguf] invalid Q6_K tensor data");
+  }
+
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  auto* weights = weights_arr.data<uint32_t>();
+  auto* scales_out = scales_arr.data<float16_t>();
+  auto* biases_out = biases_arr.data<float16_t>();
+  uint8_t values[128];
+  const uint64_t num_blocks = tensor.num_weights / weights_per_block;
+  for (uint64_t block_index = 0; block_index < num_blocks;
+       ++block_index, block += bytes_per_block) {
+    const uint8_t* ql = block;
+    const uint8_t* qh = block + 128;
+    const int8_t* encoded_scales =
+        reinterpret_cast<const int8_t*>(block + 192);
+    uint16_t d_half;
+    std::memcpy(&d_half, block + 208, sizeof(d_half));
+    const float d = from_half(d_half);
+    for (int section = 0; section < 2; ++section) {
+      for (int i = 0; i < 32; ++i) {
+        values[i] = (ql[i] & 0x0f) | (((qh[i] >> 0) & 3) << 4);
+        values[i + 32] =
+            (ql[i + 32] & 0x0f) | (((qh[i] >> 2) & 3) << 4);
+        values[i + 64] = (ql[i] >> 4) | (((qh[i] >> 4) & 3) << 4);
+        values[i + 96] =
+            (ql[i + 32] >> 4) | (((qh[i] >> 6) & 3) << 4);
+      }
+      for (int group = 0; group < 8; ++group) {
+        const float scale = d * encoded_scales[group];
+        *scales_out++ = scale;
+        *biases_out++ = -32 * scale;
+        pack_codes(values + group * 16, 16, 6, weights);
+        weights += 3;
+      }
+      ql += 64;
+      qh += 32;
+      encoded_scales += 8;
+    }
+  }
+}
