+// Decode Q6_K locally for mixed Q4 checkpoints with high-precision heads.
+void q6_k_to_f16(const gguf_tensor& tensor, uint16_t* output) {
+  constexpr uint64_t weights_per_block = 256;
+  constexpr uint64_t bytes_per_block = 210;
+  if (tensor.weights_data == nullptr ||
+      tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error("[load_gguf] invalid Q6_K tensor data");
+  }
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  uint64_t output_index = 0;
+  for (uint64_t offset = 0; offset < tensor.num_weights;
+       offset += weights_per_block, block += bytes_per_block) {
+    const uint8_t* ql = block;
+    const uint8_t* qh = block + 128;
+    const int8_t* scales = reinterpret_cast<const int8_t*>(block + 192);
+    const float d = from_half(*reinterpret_cast<const uint16_t*>(block + 208));
+    for (int section = 0; section < 2; ++section) {
+      for (int l = 0; l < 32; ++l) {
+        const int scale_index = l / 16;
+        const int q1 = ((ql[l] & 0x0f) | (((qh[l] >> 0) & 3) << 4)) - 32;
+        const int q2 = ((ql[l + 32] & 0x0f) | (((qh[l] >> 2) & 3) << 4)) - 32;
+        const int q3 = ((ql[l] >> 4) | (((qh[l] >> 4) & 3) << 4)) - 32;
+        const int q4 = ((ql[l + 32] >> 4) | (((qh[l] >> 6) & 3) << 4)) - 32;
+        output[output_index + l] = to_half(d * scales[scale_index] * q1);
+        output[output_index + l + 32] = to_half(d * scales[scale_index + 2] * q2);
+        output[output_index + l + 64] = to_half(d * scales[scale_index + 4] * q3);
+        output[output_index + l + 96] = to_half(d * scales[scale_index + 6] * q4);
+      }
+      output_index += 128;
+      ql += 64;
+      qh += 32;
+      scales += 8;
+    }
+  }
+}
