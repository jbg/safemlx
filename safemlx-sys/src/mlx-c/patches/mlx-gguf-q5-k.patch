+// Decode legacy Q5_0 locally; the pinned gguflib converter returns null.
+void q5_0_to_f16(const gguf_tensor& tensor, uint16_t* output) {
+  constexpr uint64_t weights_per_block = 32;
+  constexpr uint64_t bytes_per_block = 22;
+  if (tensor.weights_data == nullptr ||
+      tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error("[load_gguf] invalid Q5_0 tensor data");
+  }
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  uint64_t output_index = 0;
+  for (uint64_t offset = 0; offset < tensor.num_weights;
+       offset += weights_per_block, block += bytes_per_block) {
+    const float d = from_half(*reinterpret_cast<const uint16_t*>(block));
+    uint32_t qh;
+    std::memcpy(&qh, block + 2, sizeof(qh));
+    const uint8_t* qs = block + 6;
+    for (int j = 0; j < 16; ++j) {
+      const uint8_t high_low = ((qh >> j) << 4) & 0x10;
+      const uint8_t high_high = (qh >> (j + 12)) & 0x10;
+      const int low = ((qs[j] & 0x0f) | high_low) - 16;
+      const int high = ((qs[j] >> 4) | high_high) - 16;
+      output[output_index + j] = to_half(low * d);
+      output[output_index + j + 16] = to_half(high * d);
+    }
+    output_index += weights_per_block;
+  }
+}
