+// gguflib does not provide a Q5_1 converter at the pinned revision.
+void q5_1_to_f16(const gguf_tensor& tensor, uint16_t* output) {
+  constexpr uint64_t weights_per_block = 32;
+  constexpr uint64_t bytes_per_block = 24;
+  if (tensor.weights_data == nullptr) {
+    throw std::runtime_error("[load_gguf] NULL Q5_1 tensor data pointer");
+  }
+  if (tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error(
+        "[load_gguf] Q5_1 tensor length is not a whole number of blocks");
+  }
+
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  uint64_t output_index = 0;
+  for (uint64_t offset = 0; offset < tensor.num_weights;
+       offset += weights_per_block, block += bytes_per_block) {
+    const float d = from_half(*reinterpret_cast<const uint16_t*>(block));
+    const float m = from_half(*reinterpret_cast<const uint16_t*>(block + 2));
+    uint32_t qh;
+    std::memcpy(&qh, block + 4, sizeof(qh));
+    const uint8_t* qs = block + 8;
+    for (int j = 0; j < 16; ++j) {
+      const uint8_t high_low = ((qh >> j) << 4) & 0x10;
+      const uint8_t high_high = (qh >> (j + 12)) & 0x10;
+      const int low = (qs[j] & 0x0f) | high_low;
+      const int high = (qs[j] >> 4) | high_high;
+      output[output_index + j] = to_half(low * d + m);
+      output[output_index + j + 16] = to_half(high * d + m);
+    }
+    output_index += weights_per_block;
+  }
+}
