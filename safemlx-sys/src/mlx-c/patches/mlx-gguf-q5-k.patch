+// gguflib at the revision pinned by MLX 0.32.0 knows the Q5_K block size but
+// does not implement its float conversion. Decode that format locally so GGUF
+// files that use Q5_K for an isolated tensor can still be loaded safely.
+void q5_k_to_f16(const gguf_tensor& tensor, uint16_t* output) {
+  constexpr uint64_t weights_per_block = 256;
+  constexpr uint64_t bytes_per_block = 176;
+  if (tensor.weights_data == nullptr) {
+    throw std::runtime_error("[load_gguf] NULL Q5_K tensor data pointer");
+  }
+  if (tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error(
+        "[load_gguf] Q5_K tensor length is not a whole number of blocks");
+  }
+
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  uint64_t output_index = 0;
+  for (uint64_t offset = 0; offset < tensor.num_weights;
+       offset += weights_per_block, block += bytes_per_block) {
+    const float d = from_half(*reinterpret_cast<const uint16_t*>(block));
+    const float dmin =
+        from_half(*reinterpret_cast<const uint16_t*>(block + 2));
+    const uint8_t* scales = block + 4;
+    const uint8_t* qh = block + 16;
+    const uint8_t* ql = block + 48;
+
+    auto get_scale_min = [scales](int index) {
+      std::pair<uint8_t, uint8_t> result;
+      if (index < 4) {
+        result.first = scales[index] & 0x3f;
+        result.second = scales[index + 4] & 0x3f;
+      } else {
+        result.first =
+            (scales[index + 4] & 0x0f) | ((scales[index - 4] >> 6) << 4);
+        result.second =
+            (scales[index + 4] >> 4) | ((scales[index] >> 6) << 4);
+      }
+      return result;
+    };
+
+    int scale_index = 0;
+    uint8_t high_mask_low = 1;
+    uint8_t high_mask_high = 2;
+    for (int group = 0; group < 4; ++group) {
+      auto [scale_low, min_low] = get_scale_min(scale_index);
+      auto [scale_high, min_high] = get_scale_min(scale_index + 1);
+      const float d_low = d * scale_low;
+      const float m_low = dmin * min_low;
+      const float d_high = d * scale_high;
+      const float m_high = dmin * min_high;
+      for (int i = 0; i < 32; ++i) {
+        const int value =
+            (ql[i] & 0x0f) + ((qh[i] & high_mask_low) ? 16 : 0);
+        output[output_index++] = to_half(d_low * value - m_low);
+      }
+      for (int i = 0; i < 32; ++i) {
+        const int value =
+            (ql[i] >> 4) + ((qh[i] & high_mask_high) ? 16 : 0);
+        output[output_index++] = to_half(d_high * value - m_high);
+      }
+      ql += 32;
+      scale_index += 2;
+      high_mask_low <<= 2;
+      high_mask_high <<= 2;
+    }
+  }
+}
