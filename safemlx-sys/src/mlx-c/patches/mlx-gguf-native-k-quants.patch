+std::pair<uint8_t, uint8_t> qk_scale_min(
+    const uint8_t* scales,
+    int index) {
+  if (index < 4) {
+    return {scales[index] & 0x3f, scales[index + 4] & 0x3f};
+  }
+  return {
+      static_cast<uint8_t>(
+          (scales[index + 4] & 0x0f) | ((scales[index - 4] >> 6) << 4)),
+      static_cast<uint8_t>(
+          (scales[index + 4] >> 4) | ((scales[index] >> 6) << 4))};
+}
+
+void pack_32_codes(const uint8_t* codes, int bits, uint32_t* output) {
+  std::fill_n(output, bits, 0);
+  const uint32_t mask = (1u << bits) - 1;
+  for (int i = 0; i < 32; ++i) {
+    const int bit_offset = i * bits;
+    const int word = bit_offset / 32;
+    const int shift = bit_offset % 32;
+    const uint32_t value = codes[i] & mask;
+    output[word] |= value << shift;
+    if (shift + bits > 32) {
+      output[word + 1] |= value >> (32 - shift);
+    }
+  }
+}
+
+void extract_qk_data(
+    const gguf_tensor& tensor,
+    array& weights_arr,
+    array& scales_arr,
+    array& biases_arr) {
+  constexpr uint64_t weights_per_block = 256;
+  constexpr uint64_t groups_per_block = 8;
+  const bool is_q5 = tensor.type == GGUF_TYPE_Q5_K;
+  const int bits = is_q5 ? 5 : 4;
+  const uint64_t bytes_per_block = is_q5 ? 176 : 144;
+  if (tensor.weights_data == nullptr ||
+      tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error("[load_gguf] invalid Q4_K/Q5_K tensor data");
+  }
+
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  auto* weights = weights_arr.data<uint32_t>();
+  auto* scales_out = scales_arr.data<float16_t>();
+  auto* biases_out = biases_arr.data<float16_t>();
+  uint8_t codes[32];
+  const uint64_t num_blocks = tensor.num_weights / weights_per_block;
+  for (uint64_t block_index = 0; block_index < num_blocks;
+       ++block_index, block += bytes_per_block) {
+    uint16_t d_half;
+    uint16_t dmin_half;
+    std::memcpy(&d_half, block, sizeof(d_half));
+    std::memcpy(&dmin_half, block + 2, sizeof(dmin_half));
+    const float d = from_half(d_half);
+    const float dmin = from_half(dmin_half);
+    const uint8_t* encoded_scales = block + 4;
+    const uint8_t* qh = is_q5 ? block + 16 : nullptr;
+    const uint8_t* qs = is_q5 ? block + 48 : block + 16;
+
+    for (int group = 0; group < groups_per_block; ++group) {
+      const auto [scale, minimum] = qk_scale_min(encoded_scales, group);
+      *scales_out++ = d * scale;
+      *biases_out++ = -dmin * minimum;
+      const int pair = group / 2;
+      const bool high_nibble = group % 2 != 0;
+      const uint8_t high_mask = static_cast<uint8_t>(1u << group);
+      for (int i = 0; i < 32; ++i) {
+        const uint8_t packed = qs[pair * 32 + i];
+        const uint8_t low = high_nibble ? packed >> 4 : packed & 0x0f;
+        const uint8_t high = is_q5 && (qh[i] & high_mask) ? 16 : 0;
+        codes[i] = low | high;
+      }
+      pack_32_codes(codes, bits, weights);
+      weights += bits;
+    }
+  }
+}
