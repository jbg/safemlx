+void extract_q2_k_data(
+    const gguf_tensor& tensor,
+    array& weights_arr,
+    array& scales_arr,
+    array& biases_arr) {
+  constexpr uint64_t weights_per_block = 256;
+  constexpr uint64_t bytes_per_block = 84;
+  if (tensor.weights_data == nullptr ||
+      tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error("[load_gguf] invalid Q2_K tensor data");
+  }
+
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  auto* weights = weights_arr.data<uint32_t>();
+  auto* scales_out = scales_arr.data<float16_t>();
+  auto* biases_out = biases_arr.data<float16_t>();
+  uint8_t codes[weights_per_block];
+  const uint64_t num_blocks = tensor.num_weights / weights_per_block;
+  for (uint64_t block_index = 0; block_index < num_blocks;
+       ++block_index, block += bytes_per_block) {
+    const uint8_t* encoded_scales = block;
+    const uint8_t* qs = block + 16;
+    uint16_t d_half;
+    uint16_t dmin_half;
+    std::memcpy(&d_half, block + 80, sizeof(d_half));
+    std::memcpy(&dmin_half, block + 82, sizeof(dmin_half));
+    const float d = from_half(d_half);
+    const float dmin = from_half(dmin_half);
+
+    for (int group = 0; group < 16; ++group) {
+      const uint8_t encoded = encoded_scales[group];
+      *scales_out++ = d * (encoded & 0x0f);
+      *biases_out++ = -dmin * (encoded >> 4);
+      const int q_offset = (group / 8) * 32 + (group % 2) * 16;
+      const int shift = ((group % 8) / 2) * 2;
+      for (int i = 0; i < 16; ++i) {
+        codes[group * 16 + i] = (qs[q_offset + i] >> shift) & 0x03;
+      }
+    }
+    pack_codes(codes, weights_per_block, 2, weights);
+    weights += weights_per_block * 2 / 32;
+  }
+}
+
+void extract_q3_k_data(
+    const gguf_tensor& tensor,
+    array& weights_arr,
+    array& scales_arr,
+    array& biases_arr) {
+  constexpr uint64_t weights_per_block = 256;
+  constexpr uint64_t bytes_per_block = 110;
+  constexpr uint32_t mask_low_2 = 0x03030303;
+  constexpr uint32_t mask_low_4 = 0x0f0f0f0f;
+  if (tensor.weights_data == nullptr ||
+      tensor.num_weights % weights_per_block != 0) {
+    throw std::runtime_error("[load_gguf] invalid Q3_K tensor data");
+  }
+
+  const auto* block = static_cast<const uint8_t*>(tensor.weights_data);
+  auto* weights = weights_arr.data<uint32_t>();
+  auto* scales_out = scales_arr.data<float16_t>();
+  auto* biases_out = biases_arr.data<float16_t>();
+  uint8_t codes[weights_per_block];
+  const uint64_t num_blocks = tensor.num_weights / weights_per_block;
+  for (uint64_t block_index = 0; block_index < num_blocks;
+       ++block_index, block += bytes_per_block) {
+    const uint8_t* high_mask = block;
+    const uint8_t* qs = block + 32;
+    uint32_t unpacked_scales[4] = {};
+    std::memcpy(unpacked_scales, block + 96, 12);
+    const uint32_t tmp = unpacked_scales[2];
+    unpacked_scales[2] =
+        ((unpacked_scales[0] >> 4) & mask_low_4) |
+        (((tmp >> 4) & mask_low_2) << 4);
+    unpacked_scales[3] =
+        ((unpacked_scales[1] >> 4) & mask_low_4) |
+        (((tmp >> 6) & mask_low_2) << 4);
+    unpacked_scales[0] =
+        (unpacked_scales[0] & mask_low_4) |
+        (((tmp >> 0) & mask_low_2) << 4);
+    unpacked_scales[1] =
+        (unpacked_scales[1] & mask_low_4) |
+        (((tmp >> 2) & mask_low_2) << 4);
+    const auto* encoded_scales =
+        reinterpret_cast<const uint8_t*>(unpacked_scales);
+    uint16_t d_half;
+    std::memcpy(&d_half, block + 108, sizeof(d_half));
+    const float d = from_half(d_half);
+
+    for (int group = 0; group < 16; ++group) {
+      const float scale = d * (static_cast<int>(encoded_scales[group]) - 32);
+      *scales_out++ = scale;
+      *biases_out++ = -4 * scale;
+      const int q_offset = (group / 8) * 32 + (group % 2) * 16;
+      const int shift = ((group % 8) / 2) * 2;
+      const uint8_t mask = static_cast<uint8_t>(1u << (group / 2));
+      for (int i = 0; i < 16; ++i) {
+        const uint8_t low = (qs[q_offset + i] >> shift) & 0x03;
+        const uint8_t high = high_mask[(group % 2) * 16 + i] & mask ? 4 : 0;
+        codes[group * 16 + i] = low | high;
+      }
+    }
+    pack_codes(codes, weights_per_block, 3, weights);
+    weights += weights_per_block * 3 / 32;
+  }
+}
